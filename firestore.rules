rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'status', 'total', 'paymentMethod', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.status is string && data.status in ['Pending', 'Paid', 'Pending Bitcoin Payment', 'Confirmed', 'Shipped', 'Complete'] &&
             data.total is number &&
             data.paymentMethod is string && data.paymentMethod in ['paypal', 'bitcoin'] &&
             data.createdAt is string && data.createdAt.size() <= 128;
    }

    // Orders Collection
    match /orders/{orderId} {
      // Allow guests to create orders securely 
      allow create: if isValidId(orderId) && 
                       isValidOrder(incoming()) && 
                       incoming().id == orderId && 
                       incoming().keys().hasOnly(['id', 'status', 'total', 'paymentMethod', 'createdAt', 'items', 'shippingAddress']);
      // Allow reading only if the user has the exact orderId
      allow get: if isValidId(orderId);
      // No listing for guests, no updates for guests (unless authenticated, but we simplified it here)
      allow list: if false;
    }

    // Products Collection (Assuming managed via Firebase Console, public reads)
    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true;
    }
  }
}
